# Copy to .env.local for local dev, or set these on the VM at deploy time.

# --- Auth.js (Google OAuth) ---
# Generate: openssl rand -hex 32
AUTH_SECRET=<generate-with-openssl-rand-hex-32>
# From Google Cloud Console -> APIs & Services -> Credentials -> OAuth client (Web).
# Authorized redirect URI: https://<PUBLIC_HOST>/api/auth/callback/google
AUTH_GOOGLE_ID=<your-oauth-client-id>.apps.googleusercontent.com
AUTH_GOOGLE_SECRET=<your-oauth-client-secret>
# Required when running behind Caddy/any reverse proxy.
AUTH_TRUST_HOST=true

# --- llama.cpp backend (in the TEE) ---
# On the VM this is the internal docker hostname; for local dev use the SSH tunnel.
LLAMA_BASE_URL=http://llama:8000/v1
LLAMA_API_KEY=<same-key-as-the-llama-container>
# Optional: pin the served model id; otherwise fetched from /v1/models at runtime.
MODEL_NAME=

# --- Storage ---
DB_PATH=/data/app.db

# --- Provenance (build transparency) ---
# GIT_SHA / BUILD_TIME are baked in by the Docker build (ARGs). IMAGE_DIGEST is
# injected at deploy time by deploy/deploy-app.sh (a container can't know its own digest).
IMAGE_DIGEST=
