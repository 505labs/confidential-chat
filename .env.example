# Copy to .env and fill in.  ---  NEVER commit .env (it holds secrets).

# Public hostname used for the TLS certificate.
# sslip.io maps <ip-with-dashes>.sslip.io -> that IP, so just take the VM's
# external IP and replace dots with dashes. Example for 203.0.113.7:
#   PUBLIC_HOST=203-0-113-7.sslip.io
PUBLIC_HOST=<VM_IP_WITH_DASHES>.sslip.io

# Model served by llama.cpp (repo:quant on Hugging Face, auto-downloaded).
MODEL_HF=Qwen/Qwen2.5-1.5B-Instruct-GGUF:q4_k_m

# API key llama.cpp requires for inference.  Generate: openssl rand -hex 32
LLAMA_API_KEY=<generate-with-openssl-rand-hex-32>

# Open WebUI JWT signing secret.  Generate: openssl rand -hex 32
WEBUI_SECRET_KEY=<generate-with-openssl-rand-hex-32>

# Allow new user signups. true = people can register (first user becomes admin).
ENABLE_SIGNUP=true

# Role given to users AFTER the first admin:
#   pending = admin must approve each new user (default, safer)
#   user    = anyone who signs up can chat immediately (friction-free demo)
DEFAULT_USER_ROLE=pending
